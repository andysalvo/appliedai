# Applied AI Club - Environment Variables
# Copy this file to .env.local and fill in values
# Get keys from a club admin (Andy or Ryan)

OPENAI_API_KEY=sk-your-key-here

# Supabase (speaker submissions + workspace)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Apps Script endpoints (optional, for Sheets backup)
SPEAKER_SHEETS_ENDPOINT=https://script.google.com/macros/s/YOUR_SPEAKER_FORM_ID/exec
NEXT_PUBLIC_MAILING_LIST_ENDPOINT=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
NEXT_PUBLIC_LABS_MAILING_LIST_ENDPOINT=https://script.google.com/macros/s/YOUR_LABS_DEPLOYMENT_ID/exec

# Email notifications (optional, via Resend)
RESEND_API_KEY=re_your-key-here
NOTIFY_EMAIL=appliedaipsu@gmail.com
