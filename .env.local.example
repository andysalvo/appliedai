# Applied AI Club - Environment Variables
# Copy this file to .env.local and fill in values
# Get keys from a club admin (Andy or Ryan)

OPENAI_API_KEY=sk-your-key-here

# Google Apps Script endpoints (get from club admin)
NEXT_PUBLIC_MAILING_LIST_ENDPOINT=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
NEXT_PUBLIC_LABS_MAILING_LIST_ENDPOINT=https://script.google.com/macros/s/YOUR_LABS_DEPLOYMENT_ID/exec
NEXT_PUBLIC_SPEAKER_FORM_ENDPOINT=https://script.google.com/macros/s/YOUR_SPEAKER_FORM_ID/exec
